# ─────────────────────────────────────────────────────────────────────────
#  Paramètres de l'extension Firebase "Trigger Email from Firestore"
#  (firebase/firestore-send-email)
#
#  1. Copiez ce fichier en : extensions/firestore-send-email.env
#  2. Renseignez les valeurs ci-dessous (SMTP de votre fournisseur d'e-mail).
#  3. Le mot de passe SMTP n'est PAS mis ici : il est demandé comme "secret"
#     lors de l'installation (stocké dans Google Secret Manager).
#
#  Doc : https://extensions.dev/extensions/firebase/firestore-send-email
# ─────────────────────────────────────────────────────────────────────────

# Région des fonctions de l'extension (mettez la même que votre projet)
LOCATION=europe-west1

# Collection Firestore surveillée par l'extension (NE PAS changer : le site écrit dans `mail`)
MAIL_COLLECTION=mail

# Adresse expéditeur affichée dans les e-mails envoyés
DEFAULT_FROM=PDS Humanity <noreply@pdsrecords.com>

# (Optionnel) Adresse de réponse par défaut
DEFAULT_REPLY_TO=alizee.grosjean@pdsrecords.com

# Connexion SMTP de votre fournisseur (le mot de passe est saisi séparément en secret).
# Exemples :
#   Gmail / Google Workspace : smtps://USER@DOMAIN.com@smtp.gmail.com:465
#   OVH                      : smtps://USER@DOMAIN.com@ssl0.ovh.net:465
#   Office 365               : smtp://USER@DOMAIN.com@smtp.office365.com:587
SMTP_CONNECTION_URI=smtps://alizee.grosjean@pdsrecords.com@SMTP_HOST:465

# Collections optionnelles (laisser vides si non utilisées)
USERS_COLLECTION=
TEMPLATES_COLLECTION=

# Mode test (false en production)
TESTING=false
