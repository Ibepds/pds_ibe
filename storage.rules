rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Lecture publique, écriture réservée aux admins, sur tous les dossiers
    // applicatifs (participants, associations, event, content...).
    match /participants/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /associations/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /association/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /event/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /content/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
