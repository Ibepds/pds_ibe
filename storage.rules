rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /participants/{participantId}/avatar {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /association/logo {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /event/hero {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /event/gallery/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
