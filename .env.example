# ─── Firebase (public, côté client) ───
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# ─── Dons Stripe (privé, côté serveur uniquement) ───
# Clé secrète Stripe (Dashboard Stripe -> Développeurs -> Clés API)
NUXT_STRIPE_SECRET_KEY=

# Compte de service Firebase (JSON sur UNE seule ligne) pour écrire les dons
# de façon sécurisée côté serveur après vérification du paiement Stripe.
# Console Firebase -> Paramètres du projet -> Comptes de service -> Générer une clé privée.
NUXT_FIREBASE_SERVICE_ACCOUNT=
