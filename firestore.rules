rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /event/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /participants/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /schedule/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /donations/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /faq/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /association/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
